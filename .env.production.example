# 生产环境配置示例
# 复制此文件为 .env.production 并填写实际值

# 环境模式
NODE_ENV=production

# 服务端口
PORT=3000

# JWT 密钥（必须修改！）
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# OAuth 配置（如需登录功能）
VITE_APP_ID=
VITE_OAUTH_PORTAL_URL=
OAUTH_SERVER_URL=

# 数据库连接（如需保存游戏记录）
DATABASE_URL=mysql://user:password@host:3306/guandan
