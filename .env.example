# ===== 应用配置 =====
# Manus OAuth 应用 ID（可从 Manus 开发者平台获取）
VITE_APP_ID=

# ===== OAuth 认证配置（可选，留空则以访客模式运行）=====
# OAuth Portal URL（客户端使用）
VITE_OAUTH_PORTAL_URL=

# OAuth Server URL（服务器端使用）
OAUTH_SERVER_URL=

# ===== 数据库配置（可选）=====
# 数据库连接 URL（MySQL/TiDB）
# 示例：mysql://username:password@localhost:3306/guandan
DATABASE_URL=

# ===== 安全配置 =====
# JWT 加密密钥（建议使用随机生成的长字符串）
JWT_SECRET=your-secret-key-here

# ===== 管理员配置（可选）=====
# 拥有者 Open ID
OWNER_OPEN_ID=

# ===== AI Forge API 配置（可选）=====
# Forge API URL
BUILT_IN_FORGE_API_URL=

# Forge API Key
BUILT_IN_FORGE_API_KEY=

# ===== 环境 =====
# 当前环境：development 或 production
NODE_ENV=development
